PORT=4000

# Filled in during Step 4 (Stripe integration)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Filled in during Step 5 (AWS deployment) — leave blank locally if using DynamoDB Local
AWS_REGION=us-east-1
DYNAMODB_ENDPOINT=http://localhost:8000

# DynamoDB Local doesn't check these ("local"/"local" works fine for it), but
# they must be a real IAM identity with cognito-idp:AdminAddUserToGroup on
# the User Pool below for auto-enrollment into the 'customer' group to work
# (see backend/auth/cognitoGroup.js) — that call fails silently otherwise.
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Filled in during Cognito setup — a real User Pool, used even for local dev
COGNITO_USER_POOL_ID=us-east-1_replace_me
COGNITO_CLIENT_ID=replace_me
COGNITO_REGION=us-east-1

# Filled in later (USPS address validation) — leave unset to disable verification
USPS_CONSUMER_KEY=replace_me
USPS_CONSUMER_SECRET=replace_me
USPS_API_BASE_URL=https://apis.usps.com

# Optional — defaults to 60 calls/hour (USPS's default account quota) if unset
USPS_RATE_LIMIT_MAX_CALLS=60
USPS_RATE_LIMIT_WINDOW_MS=3600000

# Optional — per-IP spam protection on shipping checkouts; defaults to 10/hour if unset
IP_RATE_LIMIT_MAX_CALLS=10
IP_RATE_LIMIT_WINDOW_MS=3600000
